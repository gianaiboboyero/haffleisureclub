{
  "name": "haff-picklepulse",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Offline-first pickleball club/event system for HAFF Leisure Club.",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite --host 0.0.0.0 --config apps/web/vite.config.ts",
    "dev:network": "vite --host 0.0.0.0 --config apps/web/vite.config.ts",
    "network": "npm run dev:network",
    "dev:api": "nest start --watch",
    "build": "npm run build:web",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "preview": "vite preview --host 0.0.0.0 --config apps/web/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.0.10",
    "framer-motion": "^11.15.0",
    "howler": "^2.2.4",
    "lucide-react": "^0.468.0",
    "motion": "^12.40.0",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@types/howler": "^2.2.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
