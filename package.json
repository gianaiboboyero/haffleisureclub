{
  "name": "haff-picklepulse",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Offline-first pickleball club/event system for HAFF Leisure Club.",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "npm run dev:web",
    "dev:full": "vercel dev --listen 5173",
    "dev:web": "vite --host 0.0.0.0 --config apps/web/vite.config.ts",
    "dev:network": "vite --host 0.0.0.0 --config apps/web/vite.config.ts",
    "network": "npm run dev:network",
    "dev:api": "nest start --watch",
    "build": "npm run build:web",
    "build:web": "prisma generate && vite build --config apps/web/vite.config.ts",
    "start": "tsx server/production.ts",
    "preview": "vite preview --host 0.0.0.0 --config apps/web/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:rls": "prisma db execute --file scripts/supabase-rls.sql --schema prisma/schema.prisma",
    "db:rls-tight": "prisma db execute --file scripts/supabase-rls-tight.sql --schema prisma/schema.prisma",
    "db:rls-remaining": "prisma db execute --file scripts/supabase-rls-remaining.sql --schema prisma/schema.prisma",
    "db:rls-hardening": "prisma db execute --file scripts/supabase-rls-hardening.sql --schema prisma/schema.prisma",
    "db:rls-profile-lockdown": "prisma db execute --file scripts/supabase-rls-profile-lockdown.sql --schema prisma/schema.prisma",
    "db:storage": "prisma db execute --file scripts/supabase-storage.sql --schema prisma/schema.prisma",
    "db:seed-courts": "node scripts/seed-courts.mjs",
    "db:backup-players": "node scripts/backup-supabase-players.mjs",
    "db:import-players": "node scripts/import-players-from-json.mjs",
    "db:merge-production-roster": "node scripts/merge-production-roster.mjs",
    "db:restore-club-state": "node scripts/restore-club-state.mjs data/production-players.json --prune-orphans --clear-sessions",
    "db:seed-accounts": "node scripts/seed-accounts.mjs",
    "db:rotate-passwords": "node scripts/rotate-admin-passwords.mjs",
    "db:reset-club": "node scripts/reset-club-state.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "ably": "^2.22.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dexie": "^4.0.10",
    "express": "^4.21.2",
    "framer-motion": "^11.15.0",
    "howler": "^2.2.4",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.468.0",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/howler": "^2.2.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vercel/node": "^5.3.7",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.49.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
