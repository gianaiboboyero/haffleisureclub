# Copy this file to .env.local for local development.
# Get all values from: Supabase Dashboard → Project Settings → Database / API

# --- Postgres (Supabase) ---
# Transaction pooler — use for runtime queries
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-XX-region-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection — use for migrations (prisma db push)
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-XX-region-1.pooler.supabase.com:5432/postgres

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# VITE_USE_SUPABASE_DATA=true  # enabled by default when URL + key are set

# Never commit or expose in the browser:
# SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
INITIAL_ADMIN_EMAIL=admin@yourdomain.com
FEEDBACK_HASH_SECRET=change-this-to-a-long-random-string
FRONTEND_ORIGIN=https://yourdomain.com

# --- Optional ---
# ABLY_API_KEY=
# TURNSTILE_SECRET_KEY=
# VITE_REALTIME_CLUB=true
# VITE_REALTIME_CHAT=false
