# Copy to .env for local dev and as reference for Supabase Edge Function secrets.
# Get values from: Supabase Dashboard → Project Settings → Database / API

# --- Postgres (Supabase) ---
# Project: hmhhgmuuusknmucjlkth — https://supabase.com/dashboard/project/hmhhgmuuusknmucjlkth
# Runtime: Transaction pooler, port 6543 (copy exact URI from Dashboard → Database → Connection string)
DATABASE_URL=postgresql://postgres.hmhhgmuuusknmucjlkth:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
# Migrations / prisma db push (session pooler — direct db.* host is IPv6-only)
DIRECT_URL=postgresql://postgres.hmhhgmuuusknmucjlkth:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# --- Supabase project (browser direct data — no Vercel /api for reads) ---
# Organization: https://supabase.com/dashboard/org/koypniyxsxrkqgtztqwc
SUPABASE_ORG_SLUG=koypniyxsxrkqgtztqwc
SUPABASE_URL=https://hmhhgmuuusknmucjlkth.supabase.co
SUPABASE_PROJECT_REF=hmhhgmuuusknmucjlkth
SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Vite / Vercel frontend (maps from NEXT_PUBLIC_* at build time):
# NEXT_PUBLIC_SUPABASE_URL=https://hmhhgmuuusknmucjlkth.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# VITE_USE_SUPABASE_DATA=true   # default on when URL+key are set
# NEVER commit or expose in the browser bundle:
# SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
INITIAL_ADMIN_EMAIL=you@example.com
FEEDBACK_HASH_SECRET=change-this-to-a-long-random-string
FRONTEND_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# --- Optional ---
# ABLY_API_KEY=          # Push sync (reduces polling)
# TURNSTILE_SECRET_KEY=
# COOKIE_DOMAIN=           # Only if API shares parent domain with frontend

# --- Local dev only ---
# VITE_API_URL=http://localhost:3000
# VITE_REALTIME_CLUB=true
# VITE_REALTIME_CHAT=true
