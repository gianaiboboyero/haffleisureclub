# Copy to .env for local dev and as reference for Supabase Edge Function secrets.
# Get values from: Supabase Dashboard → Project Settings → Database / API

# --- Postgres (Supabase) ---
# Runtime: Transaction pooler, port 6543
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Migrations / prisma db push: Direct connection, port 5432
DIRECT_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# --- Supabase project (optional — for Realtime client in browser) ---
SUPABASE_URL=https://yxvebcwngxgrebybjpsy.supabase.co
SUPABASE_PROJECT_REF=yxvebcwngxgrebybjpsy
SUPABASE_ANON_KEY=your-anon-key
# NEVER commit or expose on Cloudflare Pages:
# SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
INITIAL_ADMIN_EMAIL=you@example.com
FEEDBACK_HASH_SECRET=change-this-to-a-long-random-string
FRONTEND_ORIGIN=https://yourdomain.com,https://www.yourdomain.com,https://haff-leisure-club.pages.dev

# --- Optional ---
# ABLY_API_KEY=          # Push sync (reduces polling)
# TURNSTILE_SECRET_KEY=
# COOKIE_DOMAIN=           # Only if API shares parent domain with Pages

# --- Local dev only (Cloudflare Pages uses VITE_* instead) ---
# VITE_API_URL=http://localhost:3000
# VITE_REALTIME_CLUB=true
# VITE_REALTIME_CHAT=true
