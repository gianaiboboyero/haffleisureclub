# Copy to .env on the Oracle VM: cp deploy/env.production.example .env

# --- Domains (must match Cloudflare DNS) ---
API_DOMAIN=api.haffcadiz.com
FRONTEND_ORIGIN=https://haffcadiz.com,https://www.haffcadiz.com
COOKIE_DOMAIN=.haffcadiz.com

# --- Postgres (container on same VM) ---
POSTGRES_PASSWORD=change-this-to-a-long-random-password

# --- App ---
INITIAL_ADMIN_EMAIL=you@example.com
FEEDBACK_HASH_SECRET=change-this-secret
# ABLY_API_KEY=
# TURNSTILE_SECRET_KEY=
